=== raGuvaMSe 1.1 ===

--- line ---
vAc[word]+arTa[meaning]+iva[like]=vAgarTAviva sampfkta[connected]->sampfktO
"connected together like word and meaning,"

vAc[words]+arTa[meanings]+pratipatti[knowledge]=vAgarTapratipattaye
"for the knowledge of words and meanings,"

--- line ---
jagat[world]->jagataH pitf[parents]->pitarO vand[worship]->vande[I]
"I worship the parents of the world."

pArvatI[Pārvatī]+parama[highest]+ISvara[lord]=pArvatIparameSvarO
